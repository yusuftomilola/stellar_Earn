# Application
NODE_ENV=development
PORT=3000

# Logging Configuration
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=true
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_PERFORMANCE=true
LOG_HEADERS=false
LOG_RESPONSE_BODY=false
LOG_RESPONSE_DATA=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_earn

# Migrations
TYPEORM_MIGRATIONS_TABLE=typeorm_migrations
TYPEORM_MIGRATIONS_RUN=false

# Content moderation (optional external APIs)
MODERATION_BLOCK_HIGH=true
MODERATION_HIGH_THRESHOLD=0.85
MODERATION_MEDIUM_THRESHOLD=0.5
MODERATION_BLOCKED_KEYWORDS=
MODERATION_BLOCKED_IMAGE_HOSTS=
MODERATION_EXTERNAL_API_URL=
MODERATION_EXTERNAL_API_KEY=
MODERATION_IMAGE_API_URL=
MODERATION_IMAGE_API_KEY=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Authentication Challenge
AUTH_CHALLENGE_EXPIRATION=5

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Admin Addresses (comma-separated Stellar addresses)
ADMIN_ADDRESSES=

# Email Configuration (SendGrid)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_WEBHOOK_VERIFICATION_KEY=your-webhook-verification-key
EMAIL_FROM_ADDRESS=noreply@stellarearn.com
EMAIL_FROM_NAME=Stellar Earn
EMAIL_REPLY_TO=support@stellarearn.com
APP_URL=http://localhost:3000
UNSUBSCRIBE_URL=http://localhost:3000/unsubscribe
EMAIL_QUEUE_MAX_RETRIES=5
EMAIL_QUEUE_RETRY_DELAY=5000
EMAIL_RATE_LIMIT=100

# WebSocket Configuration
WS_RATE_LIMIT_MAX=60
WS_RATE_LIMIT_WINDOW_MS=60000
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000
WS_MESSAGE_HISTORY_LIMIT=200

# CORS_ORIGINS is also used for WS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Stellar Network Configuration
STELLAR_NETWORK=testnet
# Used for Horizon API calls (e.g. account sequence)
HORIZON_URL=https://horizon-testnet.stellar.org
# Used for Soroban RPC calls (e.g. invoke contract)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Contract ID to interact with
CONTRACT_ID=C...
# Source account secret key
STELLAR_SOURCE_SECRET_KEY=S...
SOROBAN_SECRET_KEY=S...
